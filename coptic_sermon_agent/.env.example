# Anthropic API key — https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# YouTube Data API v3 key — https://console.cloud.google.com/
# Enable "YouTube Data API v3" in your project, then create an API key.
YOUTUBE_API_KEY=your_youtube_data_api_v3_key_here

# Email delivery (Gmail)
# GMAIL_SENDER:       the Gmail address you're sending FROM
# GMAIL_APP_PASSWORD: generate at myaccount.google.com/apppasswords
#                     (requires 2-Step Verification to be on)
# EMAIL_RECIPIENT:    where you want the digest delivered
GMAIL_SENDER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
EMAIL_RECIPIENT=you@gmail.com
