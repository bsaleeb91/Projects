# Anthropic API key — https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# YouTube Data API v3 key — https://console.cloud.google.com/
# Enable "YouTube Data API v3" in your project, then create an API key.
YOUTUBE_API_KEY=your_youtube_data_api_v3_key_here

# Your Gmail address (used as sender)
# No password needed — uses the same Google OAuth credentials.json
# from your morning brief setup (credentials.json + token.json in project root).
MY_EMAIL=you@gmail.com

# Where to deliver the digest (defaults to MY_EMAIL if not set)
EMAIL_RECIPIENT=you@gmail.com
